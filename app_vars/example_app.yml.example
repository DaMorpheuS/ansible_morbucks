---
# Per-app configuration. Copy to app_vars/<app>.yml (the name must match the
# OTP app / release name you pass to build.sh / deploy.sh) and edit.
#
#   cp app_vars/example_app.yml.example app_vars/my_app.yml
#
# Keep app_vars SECRET-FREE so it is safe to commit:
#   * Database name/user/password default to "<app>_<env>" (the DB is loopback
#     only). Override only if you must.
#   * secret_key_base and admin_password are generated and persisted on the box
#     at deploy time by the deploy role (roles/deploy-elixir-release/secrets.yml).

# Git remote to build from. Use https:// for a public repo (no key needed);
# use git@github.com:... for a private repo (the deploy user needs SSH access).
repo: https://github.com/DaMorpheuS/my_app.git

# Monorepo only: relative path to the mix project within the repo. Omit for a
# standalone repo (the default). The repo is cloned at its root and asdf reads
# .tool-versions there, but mix build + release run inside this subdir.
# subdir: apps/my_app

environments:

  prod:
    # --- Reverse proxy (Caddy) ------------------------------------------
    # Set `domain` to publish the app externally with an automatic TLS cert.
    # Omit `domain` to keep the app internal (no Caddy vhost).
    domain: "myapp.example.com"
    public_host: "myapp.example.com"
    http_port: 4060

    # Optional: path-based routing instead of a single upstream.
    # caddy_routes:
    #   - { path: "/api/*", port: 4060 }
    #   - { path: "/*",     upstream: "127.0.0.1:4061" }

    # --- Database (local PostgreSQL) ------------------------------------
    # database: true -> deploy creates the role/db (name=user=password=<app>_<env>)
    # and runs migrations. Omit or set false for an app with no database.
    database: true
    database_host: "127.0.0.1"
    database_port: 5432

    # --- Mail via the local SMTP relay ----------------------------------
    mail_relay: "127.0.0.1"
    mail_port: 25
    mail_from_email: "noreply@myapp.example.com"

    # --- Anything else your config.exs.j2 references --------------------
    # Non-secret values only; add keys here and reference them as {{ key }}
    # in the app's rel/overlays/config.exs.j2.

  acc:
    domain: "myapp-acc.example.com"
    public_host: "myapp-acc.example.com"
    http_port: 3060
    database: true
    database_host: "127.0.0.1"
    database_port: 5432
    mail_relay: "127.0.0.1"
    mail_port: 25
    mail_from_email: "noreply@myapp-acc.example.com"
